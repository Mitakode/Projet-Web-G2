{% extends "base.html.twig" %}

{% block title %}Les entreprises - ThePiston{% endblock %}
{% block description %}Découvrez toutes les entreprises qui recrutent des stagiaires et alternants sur ThePiston. Consultez les notes et trouvez votre futur employeur.{% endblock %}

{% block main_class %}list-page{% endblock %}
{% block content %}

    <h1 class="main-title">Les entreprises</h1>
    
    <section class="search-section">
        {# Le formulaire doit envoyer vers index.php avec l'uri #}
        <form action="/companies" method="GET" class="search-form">
            <div class="search-bar-wrapper">
                <input type="text" name="recherche" class="search-input" 
                       value="{{ search_term }}" placeholder="Rechercher une entreprise...">
                <button type="submit" class="search-btn">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
                {% if (session['user_role'] == 'admin' or session['user_role'] == 'pilote') %}
                <a href="/companies/create" class="btn-add add-link">+</a>
                {% endif %}
            </div>
        </form>
    </section>

    <section class="list-container">
        {% for company in companies_page %}
            <div class="offres-liste">
                <table class="company-table">
                    <tr>
                        <th class="company-name">{{ company.Nom_entreprise }}</th>
                        <td class="company-rating">Note : <strong>
                            {% if company.Moyenne_Note %}
                                {{ company.Moyenne_Note|round(1) }}/10
                            {% else %}
                                Pas de note
                            {% endif %}
                        </strong></td>
                        <td class="btn-table">
                            {% if session['user_role'] == 'etudiant' %}
                            <div class="rating-table">
                                {% if company.my_rating is not null %}
                                <span class="user-rating">{{ company.my_rating }}/10</span>
                                {% else %}
                                <span class="user-rating user-rating-empty">0/10</span>
                                {% endif %}
                            </div>
                                <button
                                    type="button"
                                    class="btn-action etoile {{ company.is_rated ? 'active' : '' }}"
                                    title="{{ company.my_rating is not null ? 'Modifier ma note' : 'Noter cette entreprise' }}"
                                    aria-label="{{ company.my_rating is not null ? 'Modifier ma note' : 'Noter cette entreprise' }}"
                                    onclick="ouvrirPopupNote({{ company.ID_entreprise }}, '{{ company.Nom_entreprise|e('js') }}')">
                                    <i class="fa-solid fa-star"></i>
                                </button>
                                {% endif %}
                                {% if (session['user_role'] == 'admin' or session['user_role'] == 'pilote') %}
                                <a href="/companies/update?id={{ company.ID_entreprise }}" 
                                    class="btn-action crayon">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                {# Lien de suppression avec l'ID dynamique #}
                                <a href="/companies/delete?id={{ company.ID_entreprise }}" 
                                class="btn-action poubelle" 
                                onclick="return confirm('Supprimer cette entreprise ?')">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td colspan="3" class="company-info">
                                {{ company.Contact }}
                            </td>
                        </tr>
                        <tr>
                            <td colspan="3" class="company-description">
                                {{ company.Description }}
                            </td>
                        </tr>
                    </table>
                </div>
            {% else %}
                <p>Aucune entreprise trouvée.</p>
            {% endfor %}
        </div>

        {# Système de pagination avec tes classes CSS #}
        <div class="pagination">
            {% if total_pages > 1 %}
                {% for i in 1..total_pages %}
                    <a href="/companies?recherche={{ search_term }}&page={{ i }}" 
                    class="{{ i == current_page ? 'active' : '' }}">
                        {{ i }}
                    </a>
                {% endfor %}
            {% endif %}
        </div>

{% endblock %}