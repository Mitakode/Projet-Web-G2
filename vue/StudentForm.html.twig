{% extends "base.html.twig" %}

{% block title %}{{ is_edit ? 'Modifier' : 'Ajouter' }} un étudiant - ThePiston{% endblock %}

{% block main_class %}list-page{% endblock %}
{% block content %}
<section class="frame">
    <h1 class="main-title">{{ is_edit ? 'Modifier' : 'Ajouter' }} un étudiant</h1>

    <form class="form-test" action="/{{ is_edit ? 'dashboard/admin/update-student&id=' ~ etudiant.ID_utilisateur : 'dashboard/admin/create-student' }}" method="POST">
        {% if session.user_role == 'admin' %}
            <label>ID du Pilote référent</label>
            <input class="form-input" type="number" name="id_pilote" value="{{ etudiant.ID_pilote ?? '' }}" required>
        {% endif %}
        
        <label>Nom</label>
        <input class="form-input" type="text" name="surname" value="{{ etudiant.Nom ?? '' }}" required>

        <label>Prénom</label>
        <input class="form-input" type="text" name="name" value="{{ etudiant.Prenom ?? '' }}" required>

        <label>Promotion</label>
        <input class="form-input" type="text" name="promotion" value="{{ etudiant.Promotion ?? '' }}" required>

        <label>E-mail</label>
        <input class="form-input" type="text" name="email" value="{{ etudiant.Email ?? '' }}" required>

        <label>Mot de passe</label>
        <input class="form-input" type="text" name="password" placeholder="Laissez vide pour ne pas modifier" {% if not is_edit %}required{% endif %}>

        <button class="btn" type="submit">Valider</button>
        <a href="/dashboard/admin" class="btn-annuler">Annuler</a>
    </form>
</section>
{% endblock %}