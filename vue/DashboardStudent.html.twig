{% extends "base.html.twig" %}

{% block title %}Mon espace étudiant - ThePiston{% endblock %}

{% block content %}
<main>
    <h1 class="main-title">Mon espace étudiant</h1>

    <section class="dashboards-section">
        <h2 class="dashboard-title">Mes candidatures</h2>

        <div class="box-list">
            <table class="company-table admin">
                <thead>
                    <tr>
                        <th>Titre de l'offre</th>
                        <th>Entreprise</th>
                        <th>CV</th>
                        <th>Lettre de motivation</th>
                    </tr>
                </thead>
                <tbody>
                    {% for candidature in candidatures %}
                    <tr>
                        <td>{{ candidature.Titre }}</td>
                        <td>{{ candidature.Nom_entreprise }}</td>
                        <td>{{ candidature.CV|split('/')|last }}</td>
                        <td>{{ candidature.Lettre_motivation|split('/')|last }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center;">Vous n'avez pas encore postulé à une offre.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <section class="dashboards-section">
        <h2 class="dashboard-title">Ma wishlist</h2>

        <div class="box-list">
            <table class="company-table admin">
                <thead>
                    <tr>
                        <th>Titre de l'offre</th>
                        <th>Entreprise</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for souhait in wishlist %}
                    <tr>
                        <td>{{ souhait.Titre }}</td>
                        <td>{{ souhait.Nom_entreprise }}</td>
                        <td class="btn-table">
                            <a href="index.php?uri=dashboard/student/remove-wishlist&id={{ souhait.ID_offre }}" 
                               class="btn-action poubelle" 
                               onclick="return confirm('Retirer cette offre de la wishlist ?')">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="3" style="text-align: center;">Votre wishlist est vide.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</main>
{% endblock %}