{% extends "base.html.twig" %}

{% block title %}Mon espace étudiant - ThePiston{% endblock %}

{% block content %}
    <h1 class="main-title">Mon espace étudiant</h1>

    {# Section : Mes candidatures #}
    <section class="dashboards-section">
        <h2 class="dashboard-title">Mes candidatures</h2>

        <div class="box-list">
            <table class="company-table admin">
                <thead>
                    <tr>
                        <th>Titre de l'offre</th>
                        <th>Entreprise</th>
                        <th>CV</th>
                        <th>Lettre de motivation</th>
                    </tr>
                </thead>
                <tbody>
                    {# Boucle sur les candidatures récupérées depuis le contrôleur #}
                    {% for candidature in candidatures %}
                    <tr>
                        <td>
                            <a href="/index.php?uri=offers/detail&id={{ candidature.ID_offre }}" class="link">
                                {{ candidature.Titre }}
                            </a>
                        </td>
                        <td>{{ candidature.Nom_entreprise }}</td>
                        {# Le filtre |split('/')|last permet de n'afficher que le nom du fichier PDF, sans tout le chemin du serveur #}
                        <td>{{ candidature.CV|split('/')|last }}</td>
                        <td>{{ candidature.Lettre_motivation|split('/')|last }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center;">Vous n'avez pas encore postulé à une offre.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="pagination">
            {% if total_pages > 1 %}
                {% for i in 1..total_pages %}
                    <a href="/index.php?uri=dashboard/student&page={{ i }}" 
                    class="{{ i == current_page ? 'active' : '' }}">
                        {{ i }}
                    </a>
                {% endfor %}
            {% endif %}
        </div>
    </section>

    {# Section : Ma wishlist #}
    <section class="dashboards-section">
        <h2 class="dashboard-title">Ma wishlist</h2>

        <div class="box-list">
            <table class="company-table admin">
                <thead>
                    <tr>
                        <th>Titre de l'offre</th>
                        <th>Entreprise</th>
                        <th></th> {# Colonne vide pour aligner la poubelle #}
                    </tr>
                </thead>
                <tbody>
                    {# Boucle sur la wishlist récupérée depuis le contrôleur #}
                    {% for souhait in wishlist %}
                    <tr>
                        <td>
                            <a href="/index.php?uri=offers/detail&id={{ souhait.ID_offre }}" class="link">
                                {{ souhait.Titre }}
                            </a>
                        </td>
                        <td>{{ souhait.Nom_entreprise }}</td>
                        <td class="btn-table">
                            {# Lien dynamique vers l'action de suppression dans le routeur #}
                            <a href="index.php?uri=dashboard/student/remove-wishlist&id={{ souhait.ID_offre }}" 
                               class="btn-action poubelle" 
                               onclick="return confirm('Retirer cette offre de la wishlist ?')">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="3" style="text-align: center;">Votre wishlist est vide.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="pagination">
            {% if total_pagesW > 1 %}
                {% for i in 1..total_pagesW %}
                    <a href="/index.php?uri=dashboard/student&page={{ i }}" 
                    class="{{ i == current_pageW ? 'active' : '' }}">
                        {{ i }}
                    </a>
                {% endfor %}
            {% endif %}
        </div>
    </section>
{% endblock %}