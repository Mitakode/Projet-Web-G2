{% extends "base.html.twig" %}

{# Le titre de l'onglet prend le nom de l'offre #}
{% block title %}ThePiston - {{ offre.Titre }}{% endblock %}

{% block content %}
<main>
    <section class="offer-container">
        <div class="offer-header">
            {# Affichage dynamique du titre et de l'entreprise #}
            <h1 class="offer">{{ offre.Titre }}</h1>
            <h2 class="offer">{{ offre.Nom_entreprise }}</h2>
        </div>

        <div class="form-grid">
            <div class={% if session['user_role'] == 'etudiant' %}"form-column2"{% else %}"form-column100"{% endif %}>
                <div class="frame2">
                    <div class="infos-offre">
                        {# Formatage de la date à la française #}
                        <p>Date de publication : {{ offre.Date_publication|date("d/m/Y") }}</p>
                        {# Variable fictive pour l'instant, à lier plus tard à une table de candidatures #}
                        <p>Nombre de candidatures : {{ nb_candidatures ?? 'Non spécifié' }}</p>
                    </div>

                    {# nl2br permet de respecter les retours à la ligne faits dans la description #}
                    <p class="offer-description">{{ offre.Description|nl2br }}</p>

                    <div>
                        <h2 style="margin-top: 20px;">Compétences requises</h2>
                        <ul class="skills">
                            {# On découpe la chaîne de texte à chaque virgule pour créer un tableau #}
                            {% if offre.Liste_competences %}
                                {% set competences = offre.Liste_competences|split(',') %}
                                {% for competence in competences %}
                                    {# trim enlève les espaces en trop avant ou après le mot #}
                                    <li>{{ competence|trim }}</li>
                                {% endfor %}
                            {% else %}
                                <li>Aucune compétence spécifique renseignée.</li>
                            {% endif %}
                        </ul>
                    </div>

                    <div class="offer-remuneration">
                        <h2>Rémunération</h2>
                        <p class="offer-salary">{{ offre.Base_remuneration }} €/mois</p>
                    </div>
                </div>
            </div>
            {% if session['user_role'] == 'etudiant' %}
            <div class="form-column3">
                <div class="frame2">
                    <div class="btn-container">
                        <button class="btn" type="button" id="postuler-btn">Postuler</button>
                    </div>
                    <div id="zone-depot" hidden>
                        <form class="form-test" action="/apply" method="POST" enctype="multipart/form-data">
                            
                            {# J'ajoute un champ caché très important pour que ton script PHP sache à quelle offre l'étudiant postule #}
                            <input type="hidden" name="id_offre" value="{{ offre.ID_offre }}">

                            <p class="small-text">Pour postuler à cette offre, vous devez déposer votre CV ainsi qu'une lettre de motivation.</p>
                            <div>
                                <label for="cv" class="file-label">Déposer votre CV ici (pdf)</label>
                                <input id="cv" name="cv" class="input-file" type="file" accept=".pdf" required>
                            </div>
                            <span class="file-name">Aucun fichier choisi</span>
                            
                            <div>
                                <label for="lettre" class="file-label">Déposer votre lettre de motivation ici (pdf)</label>
                                <input type="file" id="lettre" class="input-file" name="lettre" accept=".pdf" required>
                            </div>
                            <span class="file-name2">Aucun fichier choisi</span>
                            
                            <button class="btn" type="submit" id="valider">Valider</button>
                        </form>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </section>
</main>
{% endblock %}

{% block scripts %}
<script src="/assets/js/zone-depot.js"></script>
{% endblock %}
