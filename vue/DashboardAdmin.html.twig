{% extends "base.html.twig" %}

{% block title %}Mon espace - ThePiston{% endblock %}

{% block main_class %}list-page-bis{% endblock %}
{% block content %}
    {% if session['user_role'] == 'admin' %}
        <h1 class="main-title">Mon espace Administrateur</h1>
    {% else %}
        <h1 class="main-title">Mon espace Pilote</h1>
    {% endif %}

    <section class="dashboards-section">
        <h2 class="dashboard-title">Les comptes eleves</h2>

        <div class="search-container">
            <form action="/../index.php" method="GET" class="search-bar-admin">
                <input type="hidden" name="uri" value="dashboard/admin">
                <input type="text" name="surname" value="{{surname}}" placeholder="Nom">
                <input type="text" name="name" value="{{name}}" placeholder="Prenom">
                <input type="text" name="promotion" value="{{promotion}}" placeholder="Promotion">
                <button type="submit" class="search-btn" aria-label="Rechercher">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
                <button class="btn-add" id="ouvrirPopup">+</button>
            </form>
        </div>

        <div class="box-list">
            {% for etudiant in etudiants %}
            <table class="company-table admin">
                <tr>
                    <td class="user-name">{{ etudiant.Nom }} {{ etudiant.Prenom }} </td>
                    <td class="user-promotion">{{ etudiant.Promotion }}</td>
                    <td class="stats"><strong>Nombre de candidatures : {{ etudiant.nb_candidature }}</strong></td>
                    <td class="btn-table">
                        <a href="/index.php?uri=dashboard/admin/update-student&id={{ etudiant.ID_utilisateur }}" 
                            class="btn-action crayon">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        {# Lien de suppression avec l'ID dynamique #}
                        <a href="/index.php?uri=dashboard/admin/delete-student&id={{ etudiant.ID_utilisateur }}" 
                            class="btn-action poubelle" 
                            onclick="return confirm('Supprimer cet étudiant ?')">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </td>
                </tr>
            </table>
            {% endfor %}
        </div>

        {# Système de pagination avec tes classes CSS #}
        <div class="pagination">
            {% if total_pages > 1 %}
                {% for i in 1..total_pages %}
                    <a href="/index.php?uri=dashboard/admin&surname={{ surname }}&name={{ name }}&promotion={{ promotion }}&page={{ i }}" 
                    class="{{ i == current_page ? 'active' : '' }}">
                        {{ i }}
                    </a>
                {% endfor %}
            {% endif %}
        </div>
    </section>

{% if (session['user_role'] == 'admin') %}
    <section class="dashboards-section">
        <h2 class="dashboard-title">Les comptes pilotes</h2>

        <div class="search-container">
            <form action="/rechercher-pilote" method="GET" class="search-bar-admin">
                <input type="text" name="surname" placeholder="Nom">
                <input type="text" name="name" placeholder="Prenom">
                <button type="submit" class="search-btn" aria-label="Rechercher">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
                <button class="btn-add" id="ouvrirPopup">+</button>
            </form>
        </div>

        <div class="box-list">
            {% for pilote in pilotes %}
            <table class="admin-item">
                <tr>
                    <td class="user-name">{{ pilote.nom }} {{ pilote.prenom }}</td>
                    <td class="stats"><strong>Nombre d'eleves : 35</strong></td>
                    <td class="actions">
                        <button class="btn-action poubelle"><i class="fa-solid fa-trash"></i></button>
                        <button class="btn-action crayon"><i class="fa-solid fa-pen-to-square"></i></button>
                    </td>
                </tr>
            </table>
            {% endfor %}
        </div>
    </section>
{% endif %}
{% endblock %}
