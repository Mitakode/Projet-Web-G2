{% extends "base.html.twig" %}

{% block title %}{{etudiant.Nom|upper}} {{etudiant.Prenom}} - ThePiston{% endblock %}

{% block extra_head %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block main_class %}student-dashboard {% endblock %}
{% block content %}
    <h1>{{etudiant.Nom|upper}} {{etudiant.Prenom}}    {{etudiant.Promotion}}</h1>
    <div class="info-grid">
        <div class="info-column">
            <div class="info-box ib2" style="text-align: center;">Email : <strong>{{etudiant.Email}}</strong></div>
        </div>
        <div class="info-column">
            {% if session.user_role == 'admin' %}
                    <div class="info-box ib2" style="text-align: center;">Pilote référent : <strong>{{pilote.Nom}} {{pilote.Prenom}}</strong></div>
            {% endif %}
        </div>
    </div>

    <section class="dashboards-section">
        <h2 class="dashboard-title">Liste des candidatures</h2>

        <div class="box-list">
            <table class="company-table admin">
                <thead>
                    <tr>
                        <th>Titre de l'offre</th>
                        <th>Entreprise</th>
                        <th>Date de candidature</th>
                        <th>CV</th>
                        <th>Lettre de motivation</th>
                    </tr>
                </thead>
                <tbody>
                    {% for candidature in candidatures %}
                    <tr>
                        <td>
                            <a href="/offers/detail?id={{ candidature.ID_offre }}" class="link">
                                {{ candidature.Titre_offre }}
                            </a>
                        </td>
                        <td>{{ candidature.entreprise }}</td>
                        <td>{{ candidature.Date_candidature|date("d-m-Y") }}</td>
                        <td>
                            <a href="uploads/{{ candidature.CV }}" rel="nofollow" target="_blank" class="link">
                                {{ candidature.CV}}
                            </a>
                        </td>
                        <td>
                            <a href="uploads/{{ candidature.Lettre_motivation }}" rel="nofollow" target="_blank" class="link">
                                {{ candidature.Lettre_motivation}}
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="pagination">
            {% if total_pages > 1 %}
                {% for i in 1..total_pages %}
                    <a href="/dashboard/admin/student-details?id={{ etudiant.ID_utilisateur }}&page={{ i }}" 
                    class="{{ i == current_page ? 'active' : '' }}">
                        {{ i }}
                    </a>
                {% endfor %}
            {% endif %}
        </div>
    </section>
{% endblock %}
