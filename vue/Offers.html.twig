{% extends "base.html.twig" %}
{% block title %}Les offres - ThePiston{% endblock %}
{% block main_class %}list-page{% endblock %}
{% block content %}

    <h1 class="main-title">Les offres</h1>
    
    <section class="search-section">
        {# Le formulaire doit envoyer vers index.php avec l'uri #}
        <form action="/offers" method="GET" class="search-form">
            <input type="hidden" name="uri" value="offers">

            <div class="search-bar-wrapper">
                <input type="text" name="recherche" class="search-input" 
                       value="{{ search_term }}" placeholder="Rechercher une offre...">

                <button type="submit" class="search-btn">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
                {% if (session['user_role'] == 'admin' or session['user_role'] == 'pilote') %}
                {# Bouton pour ajouter une nouvelle offre #}
                <a href="/offers/create" class="btn-add add-link" id="ouvrirPopup">+</a>
                {% endif %}
            </div>
            <div class="filters-container">
                <select class="filter-item" name="type">
                    <option value="">Type d'offre</option>
                    <option value="Stage" {{ selected_type == 'Stage' ? 'selected' : '' }}>Stage</option>
                    <option value="Alternance" {{ selected_type == 'Alternance' ? 'selected' : '' }}>Alternance</option>
                </select>

                <select class="filter-item" name="duree">
                    <option value="">Durée</option>
                    <option value="1,3" {{ selected_duree == '1,3' ? 'selected' : '' }}>1-3 mois</option>
                    <option value="4,6" {{ selected_duree == '4,6' ? 'selected' : '' }}>4-6 mois</option>
                    <option value="12"  {{ selected_duree == '12'  ? 'selected' : '' }}>1 an</option>
                    <option value="24"  {{ selected_duree == '24'  ? 'selected' : '' }}>2 ans</option>
                    <option value="36"  {{ selected_duree == '36'  ? 'selected' : '' }}>3 ans</option>
                </select>
                
                <input type="text" name="company" class="filter-item" 
                       value="{{ company }}" placeholder="Entreprise...">
            </div>
        </form>
    </section>

    <div class="list-container"> 
        {# Boucle Twig : Parcours chaque offre envoyée par le contrôleur dans 'offres_page' #}
        {% for offre in offres_page %}
            <div class="offres-liste">
                <a href="/offers/detail?id={{ offre.ID_offre }}" class="link">
                    <table class="company-table offer">
                        <tr>
                            <td>
                                <div class ="infos-table">
                                    <span class="offer-name">{{ offre.Titre }}</span>
                                    {# L'affichage du nom de l'entreprise est possible grâce au JOIN dans le Modèle #}
                                    <span class="offer-company">Entreprise : <strong>{{ offre.Nom_entreprise }}</strong></span>
                                </div>
                            <td>
                            {% if (session['user_role'] == 'admin' or session['user_role'] == 'pilote') %}
                            <td class="btn-table">
                                {# Lien vers la page de modification avec l'ID de l'offre concernée #}
                                <a href="/offers/update?id={{ offre.ID_offre }}" 
                                    class="btn-action crayon">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                {# Lien de suppression avec une popup de confirmation JavaScript #}
                                <a href="/offers/delete?id={{ offre.ID_offre }}" 
                                class="btn-action poubelle" 
                                onclick="return confirm('Supprimer cette offre ?')">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                            {% endif %}
                            {% if session['user_role'] == 'etudiant' %}
                                {% if offre.has_applied == false %}
                                <td class="btn-table">
                                    {% if offre.is_in_wishlist %}
                                    <a href="/offers/deleteWishlist?id={{ offre.ID_offre }}&recherche={{ search_term }}&company={{ selected_company }}&type={{ selected_type }}&duree={{ selected_duree }}&page={{ current_page }}"
                                    class="btn-action coeur active"
                                    title="Retirer des favoris"
                                    aria-label="Retirer des favoris"><i class="fa-solid fa-heart"></i></a>
                                    {% else %}
                                    <a href="/offers/addWishlist?id={{ offre.ID_offre }}&recherche={{ search_term }}&company={{ selected_company }}&type={{ selected_type }}&duree={{ selected_duree }}&page={{ current_page }}"
                                    class="btn-action coeur"
                                    title="Ajouter aux favoris"
                                    aria-label="Ajouter aux favoris"><i class="fa-solid fa-heart"></i></a>
                                    {% endif %}
                                </td>
                                {% else %}
                                <td class="btn-table">
                                    <span class="btn-action applied" title="Deja postule" aria-label="Deja postule"><i class="fa-solid fa-file-circle-check"></i></span>
                                </td>
                                {% endif %}
                            {% endif %}
                        </tr>
                        <tr>
                            <td colspan="3" class="company-info">
                                {# Affichage des données de base de l'offre avec formatage de la date #}
                                Durée : {{ offre.Duree }} mois | Publié le : {{ offre.Date_publication|date("d/m/Y") }}
                            </td>
                        </tr>
                        <tr>
                            <td colspan="3" class="company-description">
                                {{ offre.Description|slice(0, 90) ~ '...' }}
                            </td>
                        </tr>
                    </table>
                </a>
            </div>
        {# S'exécute si le tableau 'offres_page' est vide (aucune offre ne correspond à la recherche) #}
        {% else %}
            <p>Aucune offre trouvée.</p>
        {% endfor %}
    </div>

    {# Système de pagination #}
    <div class="pagination">
        {% if total_pages > 1 %}
            {# Boucle de 1 jusqu'au nombre total de pages #}
            {% for i in 1..total_pages %}
                {# Ajout de la classe 'active' si 'i' correspond à la page actuelle #}
                     <a href="/offers?recherche={{ search_term }}&company={{ selected_company }}&type={{ selected_type }}&duree={{ selected_duree }}&page={{ i }}" 
                   class="page-link {{ i == current_page ? 'active' : '' }}">
                    {{ i }}
                </a>
            {% endfor %}
        {% endif %}
    </div>
{% endblock %}
